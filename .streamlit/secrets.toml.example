# ── Método recomendado (evita problemas con la private_key) ──────────────────
# Abre el archivo JSON de credenciales, copia TODO el contenido en una sola línea
# y pégalo como valor de json_str (entre comillas simples).
#
# Ejemplo:
# [gcp_service_account]
# json_str = '{"type":"service_account","project_id":"master-plateau-489706","private_key_id":"abc123","private_key":"-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n","client_email":"xxx@master-plateau-489706.iam.gserviceaccount.com","client_id":"000","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://..."}'

[gcp_service_account]
json_str = 'PEGA_AQUI_EL_CONTENIDO_COMPLETO_DEL_JSON_EN_UNA_SOLA_LINEA'
